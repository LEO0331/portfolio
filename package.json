{
  "name": "portfolio-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:sitemap": "node tools/generate-sitemap.mjs",
    "generate:robots": "node tools/generate-robots.mjs",
    "prebuild": "npm run generate:sitemap && npm run generate:robots",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test && node tools/e2e-coverage-check.mjs",
    "test:e2e:ui": "playwright test --ui",
    "sync:projects": "node tools/sync-projects-from-github.mjs",
    "test:e2e:flow": "./tools/e2e/playwright_user_flow.sh http://127.0.0.1:4173/portfolio",
    "test:e2e:flow:mobile": "./tools/e2e/playwright_user_flow_mobile.sh http://127.0.0.1:4173/portfolio",
    "test:e2e:flow:routes": "./tools/e2e/playwright_user_flow_routes.sh http://127.0.0.1:4173/portfolio",
    "test:e2e:flow:all": "./tools/e2e/playwright_user_flow_all.sh http://127.0.0.1:4173/portfolio"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  }
}
